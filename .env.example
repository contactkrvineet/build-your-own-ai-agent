# =============================================================================
# AskVineet — Environment Variables Template
# Copy this file to .env and fill in your secrets.
# NEVER commit the .env file.
# =============================================================================

# ── LLM Provider API Keys ────────────────────────────────────────────────────
# Provide the key for whichever provider is set in config.yaml → llm.provider

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GOOGLE_API_KEY=AIza...                  # Gemini
HUGGINGFACE_API_TOKEN=hf_...

# Ollama needs no API key — just a running local server

# ── Weather Tool ─────────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your_owm_key_here

# ── Google APIs (Gmail + Calendar) ───────────────────────────────────────────
# Download credentials.json from Google Cloud Console → OAuth 2.0 Clients
GOOGLE_CREDENTIALS_FILE=./credentials.json
GOOGLE_TOKEN_FILE=./data/google_token.json

# ── Custom REST API Tool ─────────────────────────────────────────────────────
CUSTOM_API_ENDPOINT=https://api.example.com/data
CUSTOM_API_KEY=your_custom_api_key_here
CUSTOM_API_HEADER_NAME=Authorization
CUSTOM_API_HEADER_VALUE=Bearer your_token_here

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                     # development | staging | production
SECRET_KEY=change-me-to-a-random-32-char-string

# ── Vector Store ─────────────────────────────────────────────────────────────
# Optional: Pinecone (if switching from local ChromaDB/FAISS)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ── Observability (optional) ─────────────────────────────────────────────────
# LangSmith tracing — free tier available at smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=askvineet

# LiteLLM verbose logging
LITELLM_LOG=ERROR                       # DEBUG | INFO | ERROR
